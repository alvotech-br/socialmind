NODE_ENV=development

# Database
DATABASE_URL=postgresql://user:pass@localhost:5432/socialplatform_dev
DATABASE_URL_TEST=postgresql://user:pass@localhost:5432/socialplatform_test

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=

# Storage (MinIO em local, S3 em HML/PROD)
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=socialplatform-local
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Stripe (vazio em local)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# i18n
DEFAULT_LOCALE=pt-BR

# URLs
APP_URL=http://localhost:3000
API_URL=http://localhost:3001

# Seed (opcional)
SEED_USER_EMAIL=
SEED_USER_PASSWORD=
SEED_USER2_EMAIL=
SEED_USER2_PASSWORD=
